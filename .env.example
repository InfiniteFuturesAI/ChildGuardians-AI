# =============================================================================
# CHILD GUARDIANS - Environment Variables Template
# =============================================================================
# Copy this file to .env and customize for your environment
# NEVER commit .env files with real secrets to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///data/child_guardians.db
DB_POOL_SIZE=5

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-a-real-one

# Require TLS for all connections (should be true in production)
REQUIRE_TLS=true

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FILE=/var/log/child-guardians/app.log

# -----------------------------------------------------------------------------
# Audit Trail
# -----------------------------------------------------------------------------
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=2555  # 7 years

# -----------------------------------------------------------------------------
# Hash Registry
# -----------------------------------------------------------------------------
HASH_REGISTRY_PATH=data/hash_registry.db

# -----------------------------------------------------------------------------
# API Settings
# -----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# Data Storage
# -----------------------------------------------------------------------------
DATA_DIR=./data
